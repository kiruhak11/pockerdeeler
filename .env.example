# Postgres credentials
POSTGRES_USER=poker
POSTGRES_PASSWORD=poker
POSTGRES_DB=pokerdb

# Docker-mapped ports (override if ports are busy on your machine)
APP_PORT=3000
POSTGRES_PORT=5432
PGBOUNCER_PORT=6432
REDIS_PORT=6379
ADMINER_PORT=8080

# Application DB URLs
# For production-like docker-compose with PgBouncer:
DATABASE_URL=postgresql://poker:poker@pgbouncer:5432/pokerdb?schema=public&pgbouncer=true&connection_limit=1
# For migrations always use direct PostgreSQL URL:
DIRECT_DATABASE_URL=postgresql://poker:poker@postgres:5432/pokerdb?schema=public
# Local (no Docker) example:
# DATABASE_URL=postgresql://poker:poker@localhost:5432/pokerdb?schema=public
# DIRECT_DATABASE_URL=postgresql://poker:poker@localhost:5432/pokerdb?schema=public

JWT_SECRET=change-me-jwt-secret
ROOM_SECRET_PEPPER=change-me-room-pepper
NUXT_PUBLIC_APP_URL=http://localhost:3000
REDIS_URL=redis://redis:6379
NODE_ENV=development
